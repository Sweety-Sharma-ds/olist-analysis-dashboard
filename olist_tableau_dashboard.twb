    <worksheet name='Sheet 10'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Times New Roman' fontsize='11'>On-Time delivery</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Multiple Connections' name='federated.0t3vp390z5rpvh1bipwad15m5dkb' />
          </datasources>
          <datasource-dependencies datasource='federated.0t3vp390z5rpvh1bipwad15m5dkb'>
            <column caption='delivery status' datatype='integer' name='[Calculation_1017937104965642]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF NOT ISNULL([order_delivered_customer_date]) THEN&#13;&#10;    IF [order_delivered_customer_date] &lt;= [order_estimated_delivery_date]&#13;&#10;    THEN 1 ELSE 0 END&#13;&#10;END' />
            </column>
            <column caption='On-time delivery' datatype='real' default-format='p0.00%' name='[Calculation_1017937105211403]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1017937104965642]) / COUNT([Calculation_1017937104965642])' />
            </column>
            <column caption='Order Delivered Customer Date' datatype='datetime' name='[order_delivered_customer_date]' role='dimension' type='ordinal' />
            <column caption='Order Estimated Delivery Date' datatype='datetime' name='[order_estimated_delivery_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1017937105211403]' derivation='User' name='[usr:Calculation_1017937105211403:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-align' value='center' />
            <format attr='color' value='#00aa00' />
            <format attr='font-weight' value='bold' />
          </style-rule>
          <style-rule element='label'>
            <format attr='text-align' value='center' />
          </style-rule>
        </style>
