    <worksheet name='Sheet 4'>
      <table>
        <view>
          <datasources>
            <datasource caption='Multiple Connections' name='federated.0t3vp390z5rpvh1bipwad15m5dkb' />
          </datasources>
          <datasource-dependencies datasource='federated.0t3vp390z5rpvh1bipwad15m5dkb'>
            <column caption='order per customer' datatype='integer' name='[Calculation_1017937074065408]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed[customer_unique_id]:COUNTD([order_id])}' />
            </column>
            <column caption='loyal segmentation' datatype='string' name='[Calculation_1017937076187137]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1017937074065408] = 1 THEN &quot;One-Time Buyer&quot;&#13;&#10;ELSEIF [Calculation_1017937074065408] &lt;= 3 THEN &quot;Occasional Buyer&quot;&#13;&#10;ELSEIF [Calculation_1017937074065408] &lt;= 5 THEN &quot;Repeat Customer&quot;&#13;&#10;ELSE &quot;Loyal Customer&quot;&#13;&#10;END' />
