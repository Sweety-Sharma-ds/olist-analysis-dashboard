      <aliases enabled='yes' />
      <column caption='revenue' datatype='real' name='[Calculation_0795010077745152]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price]+[freight_value])' />
      </column>
      <column caption='order per customer' datatype='integer' name='[Calculation_1017937074065408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{fixed[customer_unique_id]:COUNTD([order_id])}' />
      </column>
      <column caption='loyal segmentation' datatype='string' name='[Calculation_1017937076187137]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1017937074065408] = 1 THEN &quot;One-Time Buyer&quot;&#13;&#10;ELSEIF [Calculation_1017937074065408] &lt;= 3 THEN &quot;Occasional Buyer&quot;&#13;&#10;ELSEIF [Calculation_1017937074065408] &lt;= 5 THEN &quot;Repeat Customer&quot;&#13;&#10;ELSE &quot;Loyal Customer&quot;&#13;&#10;END' />
      </column>
      <column caption='avg delivery days' datatype='integer' name='[Calculation_1017937089253378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[order_approved_at],[order_delivered_customer_date])' />
      </column>
      <column caption='is repeted customer' datatype='integer' name='[Calculation_1017937100349445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1017937074065408] &gt; 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='percentage repeated' datatype='real' default-format='p0.00%' name='[Calculation_1017937100496902]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1017937100349445]) / COUNTD([customer_id])' />
      </column>
      <column caption='max order' datatype='integer' name='[Calculation_1017937100996615]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Calculation_1017937074065408])' />
      </column>
      <column caption='Total order' datatype='integer' name='[Calculation_1017937103478792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Average order value' datatype='real' name='[Calculation_1017937104121865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value]) / COUNTD([order_id])' />
      </column>
      <column caption='delivery status' datatype='integer' name='[Calculation_1017937104965642]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([order_delivered_customer_date]) THEN&#13;&#10;    IF [order_delivered_customer_date] &lt;= [order_estimated_delivery_date]&#13;&#10;    THEN 1 ELSE 0 END&#13;&#10;END' />
      </column>
      <column caption='On-time delivery' datatype='real' default-format='p0.00%' name='[Calculation_1017937105211403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1017937104965642]) / COUNT([Calculation_1017937104965642])' />
      </column>
      <column caption='peak month' datatype='string' name='[Calculation_1017937168539660]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([payment_value]) =&#13;&#10;  WINDOW_MAX(SUM([payment_value]))&#13;&#10;THEN &quot;Peak&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Repeated customers (copy)' datatype='real' default-format='p0.00%' name='[Repeated customers (copy)_1017937097367556]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(1.0 * COUNTD(IF {FIXED [customer_id] : COUNTD([order_id])} &gt; 1 THEN [customer_id] END))&#13;&#10;/ &#13;&#10;COUNTD([customer_id])' />
      </column>
